{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Pleio: Start",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\pleio-local.ps1",
        "-Action",
        "start"
      ],
      "problemMatcher": []
    },
    {
      "label": "Pleio: Stop",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\pleio-local.ps1",
        "-Action",
        "stop"
      ],
      "problemMatcher": []
    },
    {
      "label": "Pleio: Status",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\pleio-local.ps1",
        "-Action",
        "status"
      ],
      "problemMatcher": []
    },
    {
      "label": "Pleio: Logs",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\pleio-local.ps1",
        "-Action",
        "logs"
      ],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Pleio: Verify",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\pleio-local.ps1",
        "-Action",
        "verify"
      ],
      "problemMatcher": []
    },
    {
      "label": "Pleio: Init",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\pleio-local.ps1",
        "-Action",
        "init"
      ],
      "problemMatcher": []
    },
    {
      "label": "Pleio: Reset (destructive)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\pleio-local.ps1",
        "-Action",
        "reset"
      ],
      "problemMatcher": []
    },
    {
      "label": "Pleio: Frontend (Vite dev server)",
      "type": "shell",
      "command": "corepack yarn dev",
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "Vite"
      }
    }
  ]
}
